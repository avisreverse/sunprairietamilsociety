# Sun Prairie Tamil Society — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git — it's in .gitignore

# ─── Supabase (SPTS Society — SEPARATE project from spts-clean) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # SERVER-SIDE ONLY — never NEXT_PUBLIC_

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sunprairietamilsociety.vercel.app  # Production URL (custom domain: sunprairietamilsociety.com pending)

# ─── Google Drive (Gallery) ───────────────────────────────────────────────────
# D-014: Google Drive for gallery — no photo migration cost
GOOGLE_DRIVE_API_KEY=your-api-key-here                 # SERVER-SIDE ONLY — never NEXT_PUBLIC_
GOOGLE_DRIVE_FOLDER_ID=your-shared-folder-id           # Public shared gallery folder

# ─── Email (iCloud SMTP — same config as spts-clean) ─────────────────────────
# D-011: Nodemailer + iCloud SMTP
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=your-icloud-email@icloud.com
SMTP_PASS=your-app-specific-password                   # Generate at appleid.apple.com
FROM_EMAIL=your-icloud-email@icloud.com
FROM_NAME=Sun Prairie Tamil Society

# ─── Sentry (Error Monitoring) ───────────────────────────────────────────────
# D-010: Sentry from day 1 — app works without this but errors won't be captured
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
